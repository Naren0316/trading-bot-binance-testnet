# Copy this file to .env and fill in your Binance Futures Testnet API credentials.
# Get these from https://testnet.binancefuture.com after registering/logging in
# (Futures Testnet uses its own separate account/API keys from Spot Testnet).

BINANCE_API_KEY=your_testnet_api_key_here
BINANCE_API_SECRET=your_testnet_api_secret_here
